# Root gitignore
# Ignore node_modules everywhere
node_modules/
*/node_modules/

# Ignore environment variables
.env
.env.local
.env.*
*.db
*.db-journal


# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*

# Mac OS
.DS_Store

# Frontend specific overrides
frontend/.next/
frontend/out/
frontend/build
frontend/.vercel
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/.clerk/
